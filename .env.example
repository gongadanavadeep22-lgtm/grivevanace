# Database - SQLite for local (no setup). For Vercel use Turso or Neon.
DATABASE_URL=file:./dev.db

# Auth (required for production)
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Production URL (Vercel sets automatically, or set for custom domain)
NEXTAUTH_URL=https://your-app.vercel.app

# Optional: Gemini API (for photo analysis if re-enabled)
GEMINI_API_KEY=your_gemini_api_key
